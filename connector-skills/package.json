{
  "name": "@topaca/connector-skills",
  "version": "0.0.1",
  "description": "Connector skill contracts and mock adapters for Nova (Mail, Calendar, Files, Messaging, Search, Browser, IDE, Media)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "check": "tsgo --noEmit -p tsconfig.build.json"
  },
  "keywords": [
    "nova",
    "edgent",
    "connectors",
    "skills",
    "mail",
    "calendar",
    "files",
    "messaging",
    "search",
    "browser",
    "ide",
    "media"
  ],
  "author": "TOPACA AI-Lab (Markus Ertel) <hello@topaca.com>",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "grammy": "^1.42.0",
    "imapflow": "^1.3.2",
    "nodemailer": "^8.0.6",
    "tsdav": "^2.1.8",
    "webdav": "^5.9.0"
  }
}
