{
  "name": "@topaca/orchestration-core",
  "version": "0.0.1",
  "description": "Core orchestration runtime for Nova jobs, schedules, and execution lifecycle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"check": "tsgo --noEmit -p tsconfig.build.json"
	},
  "keywords": [
    "nova",
    "orchestration",
    "scheduler",
    "jobs",
    "automation"
  ],
  "author": "TOPACA AI-Lab (Markus Ertel) <hello@topaca.com>",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.7.3"
  }
}
